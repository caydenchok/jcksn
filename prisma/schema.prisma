generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Property {
  id              Int      @id @default(autoincrement())
  title           String
  description     String
  price           Float
  propertyType    String
  propertyCategory String @default("residential")
  purpose         String   @default("Buy")
  tenure          String
  furnishing      String
  lotType         String
  status          String
  location        String
  state           String
  size            String
  landSize        String
  bedrooms        Int
  bathrooms       Int
  carParks        Int
  features        String
  images          String
  nearbyFacilities String @default("[]")
  bookings        Booking[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AgentProfile {
  id          Int      @id @default(autoincrement())
  name        String
  phone       String
  email       String   @default("")
  company     String   @default("")
  licenseNo   String   @default("")
  tagline     String   @default("Your trusted property agent")
  bio         String   @default("")
  welcomeMsg  String   @default("")
  enabledCommands String @default("[]")
  languages   String   @default("English, Malay")
  specialities String  @default("Residential, Commercial")
  profilePic  String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lead {
  id          Int      @id @default(autoincrement())
  name        String   @default("")
  phone       String   @default("")
  email       String   @default("")
  source      String
  message     String   @default("")
  location    String   @default("")
  budget      String   @default("")
  requirement String   @default("")
  status      String   @default("new")
  notes       String   @default("")
  profileUrl  String   @default("")
  nameVerified Boolean @default(false)
  matchedPropertyId Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Booking {
  id            Int      @id @default(autoincrement())
  customerName  String
  customerPhone String
  propertyId    Int
  property      Property @relation(fields: [propertyId], references: [id])
  bookingType   String   // "viewing" | "callback"
  date          String
  time          String
  status        String   @default("pending")
  notes         String?
  createdAt     DateTime @default(now())
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Conversation {
  id            Int       @id @default(autoincrement())
  phone         String    @unique
  name          String?
  lastMessage   String
  lastActive    DateTime  @default(now())
  createdAt     DateTime  @default(now())
  needsHandoff  Boolean   @default(false)
  handoffNote   String?
  lastFollowUp  DateTime?
  followUpCount Int       @default(0)
  messages      ChatMessage[]
}

model ChatMessage {
  id             Int          @id @default(autoincrement())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId Int
  role           String
  content        String
  timestamp      DateTime     @default(now())
}
