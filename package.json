{
  "name": "jcksn",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "author": "JCKSN",
  "description": "AI-powered property assistant",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder --win",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:all": "npm run build && electron-builder --win --mac",
    "electron:build:linux": "npm run build && electron-builder --linux",
    "postinstall": "prisma generate"
  },
  "build": {
    "appId": "com.jcksn.property",
    "productName": "JCKSN",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      ".next/standalone/.next/**/*",
      ".next/standalone/node_modules/**/*",
      ".next/standalone/server.js",
      ".next/standalone/package.json",
      ".next/static/**/*",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      },
      {
        "from": "dev.db",
        "to": "dev.db"
      },
      {
        "from": "whatsapp-auth",
        "to": "whatsapp-auth"
      }
    ],
    "asar": false,
    "asarUnpack": [
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*",
      "server.js"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "public/icon-512.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "public/icon-512.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon-512.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JCKSN"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@libsql/client": "^0.17.4",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/qrcode": "^1.5.6",
    "@types/three": "^0.185.0",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "jimp": "^1.6.1",
    "lucide-react": "^1.21.0",
    "multer": "^2.2.0",
    "next": "16.2.9",
    "openai": "^6.45.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.12.0",
    "sharp": "^0.35.2",
    "tailwind-merge": "^3.6.0",
    "three": "^0.185.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/multer": "^2.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^8.0.5"
  }
}
