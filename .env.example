# Database - Local (Electron/Desktop)
DATABASE_URL="file:./dev.db"

# Database - Cloud (Vercel/Production)
# Option 1: Turso (recommended for production)
# TURSO_DATABASE_URL="libsql://your-db-name-your-org.turso.io"
# TURSO_AUTH_TOKEN="your-auth-token"

# AI Provider: "deepseek" (primary) or "ollama" (fallback)
AI_PROVIDER=deepseek

# DeepSeek API (primary - recommended)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash

# Ollama (local fallback - auto-used when DeepSeek fails)
# Install Ollama from https://ollama.com
# Then run: ollama pull llama3.2
OLLAMA_MODEL=llama3.2

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
